{
  "name": "blog-generator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "npm test && npm run lint && npm run depcruise && npm run duplication && npm audit --audit-level=low",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest --coverage --watchman=false && node src/scripts/write-coverage-summary.js",
    "tsdoc:check": "tsc --project tsconfig.jsdoc.json",
    "test:e2e": "playwright test",
    "generate": "node src/build/generate.js",
    "test-watch": "node --experimental-vm-modules ./node_modules/.bin/jest --watchAll",
    "tcr": "./tcr.sh",
    "build-and-tcr": "npm run build:browser && npm run tcr",
    "stryker": "node --experimental-vm-modules ./node_modules/.bin/stryker run",
    "sonar-issues": "src/scripts/get-sonar-issues.sh",
    "lint": "npx eslint . --fix --no-color --format=stylish -o reports/lint/lint.txt; cat reports/lint/lint.txt",
    "copy": "node src/build/copy.js",
    "copy:dendrite": "node src/build/copy-dendrite.js",
    "build:cloud": "node src/build/copy-cloud.js",
    "build:mattheard-net": "npm run copy && npm run generate",
    "build:dendritestories-co-nz": "npm run copy:dendrite",
    "build:browser": "npm run build:mattheard-net",
    "build": "npm run build:mattheard-net",
    "depcruise": "depcruise --config dependency-cruiser.config.cjs src",
    "duplication": "jscpd",
    "start": "npx serve public",
    "start:symphony": "node src/local/symphony/server.js",
    "symphony:tui": "node scripts/symphony-tui.js",
    "start:writer:playwright": "node src/local/server.js",
    "start:writer": "node src/local/server.js",
    "start:writer:watch": "node --watch src/local/server.js"
  },
  "devDependencies": {
    "@babel/preset-env": "7.26.9",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@stryker-mutator/core": "9.6.0",
    "@stryker-mutator/jest-runner": "9.6.0",
    "@types/express": "5.0.6",
    "complexity-report": "2.0.0-alpha",
    "cors": "2.8.5",
    "dependency-cruiser": "17.3.10",
    "dotenv": "16.6.1",
    "escomplex": "2.0.0-alpha",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-jsdoc": "51.3.3",
    "eslint-plugin-prettier": "5.5.1",
    "express": "4.22.1",
    "firebase": "12.0.0",
    "globals": "16.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "30.3.0",
    "jscpd": "4.0.5",
    "madge": "8.0.0",
    "prettier": "3.5.3",
    "typescript": "5.9.3",
    "typhonjs-escomplex": "0.1.0"
  },
  "overrides": {
    "eslint": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    }
  }
}
