{
  "name": "blog-generator",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check": "node src/local/run-check.js",
    "check:fast": "node src/local/run-check.js --fail-fast",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node scripts/run-jest-with-coverage.js",
    "tsdoc:check": "tsc --project tsconfig.jsdoc.json",
    "test:e2e": "node scripts/run-e2e.js",
    "test:e2e:cloud": "node scripts/run-e2e.js --mode cloud",
    "test:e2e:local": "npm run build && node scripts/run-e2e.js --mode local",
    "generate": "node src/build/generate.js",
    "gh:watch": "node scripts/watch-gh-run.js",
    "test-watch": "node --experimental-vm-modules ./node_modules/.bin/jest --watchAll",
    "tcr": "./tcr.sh",
    "build-and-tcr": "npm run build:browser && npm run tcr",
    "mutant:all": "node --experimental-vm-modules ./node_modules/.bin/stryker run",
    "mutant:worktree": "node src/local/run-stryker-worktree.js",
    "mutant:find": "node src/local/find-surviving-mutant.js",
    "sonar-issues": "src/local/get-sonar-issues.sh",
    "lint": "npx eslint . --fix --max-warnings=0 --no-color --format=stylish -o reports/lint/lint.txt && cat reports/lint/lint.txt",
    "copy": "node src/build/copy.js",
    "copy:dendrite": "node src/build/copy-dendrite.js",
    "build:cloud": "node src/build/copy-cloud.js",
    "build:mattheard-net": "npm run copy && npm run generate",
    "build:dendritestories-co-nz": "npm run copy:dendrite",
    "build:browser": "npm run build:mattheard-net",
    "build": "npm run build:mattheard-net",
    "depcruise": "node src/local/check-depcruise.js",
    "duplication": "node src/local/check-duplication.js",
    "entrypoint-pattern": "node src/local/check-build-entrypoint-pattern.js",
    "non-core-thin": "node src/local/check-non-core-thin-files.js",
    "start": "npx serve public",
    "start:symphony": "node src/local/symphony/server.js",
    "start:gcp-simulator": "node src/local/gcp-simulator/server.js",
    "symphony:tui": "node scripts/symphony-tui.js",
    "notion:codex:poll": "node scripts/notion-codex-poll.js",
    "notion:codex:poll:dry": "node scripts/notion-codex-poll.js --dry-run",
    "start:notion-symphony": "node scripts/notion-codex-poll.js --watch",
    "notion:codex:append-reply": "node scripts/notion-codex-append-reply.js",
    "start:writer:playwright": "node src/local/server.js",
    "start:writer": "node src/local/server.js",
    "start:writer:watch": "node --watch src/local/server.js",
    "start:local": "WRITER_HOST=0.0.0.0 node src/local/server.js"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/express": "5.0.6",
    "complexity-report": "2.0.0-alpha",
    "cors": "2.8.5",
    "dependency-cruiser": "^17.4.3",
    "dotenv": "16.6.1",
    "escomplex": "2.0.0-alpha",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-jsdoc": "51.3.3",
    "eslint-plugin-prettier": "5.5.1",
    "express": "^4.22.2",
    "firebase": "^12.14.0",
    "globals": "16.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jscpd": "4.0.5",
    "madge": "8.0.0",
    "prettier": "3.5.3",
    "typescript": "5.9.3",
    "typhonjs-escomplex": "0.1.0"
  },
  "overrides": {
    "js-yaml": "4.2.0",
    "qs": "6.15.2",
    "eslint": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    }
  }
}
